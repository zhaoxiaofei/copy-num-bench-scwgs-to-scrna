# ==============================================================================
# InferCNV: https://github.com/broadinstitute/infercnv
#   requires ref cell IDs for normalization
# ==============================================================================

# CAVEAT: inferCNV does not always generate integer copy numbers, 
#   and its manual at https://github.com/broadinstitute/inferCNV/wiki states that inferCNV outputs relative intensities 
#   (instead of absolute copy numbers)
# Therefore, we only check the expression-based CNV at infercnv.observations.txt, which is always generated.
# infercnv.20_HMM_predHMMi6.leiden.hmm_mode-subclusters.Pnorm_0.5.repr_intensities.observations.txt

if always_has_ref_cells:

    rule run_infercnv_hg19_with_given_ref:
        input:
            matrix = SELECTED_COUNT_MATRIX,
            annot = RNA_BEST_ANNOTATION,
            ref_groups = f"data/{DATASET}_input/ref_groups.txt",
            gene_pos = GENE_POS_FILE_HG19,
        output:
            cnv_file = f"results/{mat_specific_dataset}_output/infercnv_known_ref_hg19/infercnv.observations.txt",
            # states_file = f"results/{mat_specific_dataset}_output/infercnv_known_ref_hg19/infercnv.20_HMM_predHMMi6.leiden.hmm_mode-subclusters.Pnorm_0.5.repr_intensities.observations.txt"
