# ==============================================================================
# CaSpER: https://github.com/akdess/CaSpER 
#   requires scRNA BAM for BAF extraction
#   requires ref cell IDs for normalization
# ==============================================================================

if (MODE == "fastq" or MODE == "bam") and always_has_ref_cells:

    rule casper_merge_scrna_bams:
        input:
            bams = [ALL_SCRNA_BAM_OF[c] for c in ALL_CELL_IDS]
        output:
            merged = f"results/{mat_specific_dataset}_output/casper_known_ref/merged.bam",
            merged_bai = f"results/{mat_specific_dataset}_output/casper_known_ref/merged.bam.bai"
        log:
            f"logs/{mat_specific_dataset}/{mat_specific_dataset}_casper_merge_{dataset}_bams.log"
        threads: 4
        resources:
            mem_mb = 8000
        shell:
            r"""
            set -euo pipefail
            mkdir -p $(dirname {output.merged})
            samtools merge -@ {threads} -f {output.merged} {input.bams} 2>{log}
            samtools index {output.merged} 2>>{log}
            """

    rule run_BAFextract_casper:
        input:
            bam_file = f"results/{mat_specific_dataset}_output/casper_known_ref/merged.bam"
        output:
            out_dir = directory(f"results/{mat_specific_dataset}_output/casper_known_ref/{dataset}_bins_BAFExtract"),
            af      = f"results/{mat_specific_dataset}_output/casper_known_ref/{dataset}_BAFExtract/{dataset}_BAFExtract.af"
        log:
            f"logs/{mat_specific_dataset}/{mat_specific_dataset}_casper_preprocess.log"
        benchmark:
            f"benchmarks/{mat_specific_dataset}/{mat_specific_dataset}_casper_preprocess_benchmark.txt"
        threads: 1
        resources:
            mem_mb = 24000
        params:
            genome_list = BAFEXTRACT_GENOME_LIST,
            genome      = BAFEXTRACT_GENOME,
            bafextract  = BAFEXTRACT_BIN
        shell:
            r"""
            set -euo pipefail
            mkdir -p {output.out_dir}
            mkdir -p $(dirname {output.af})
            samtools view {input.bam_file} \
                | {params.bafextract} -generate_compressed_pileup_per_SAM stdin \
                    {params.genome_list} {output.out_dir} 50 0 2>{log}
            {params.bafextract} -get_SNVs_per_pileup \
                {params.genome_list} {output.out_dir} {params.genome} 20 4 0.1 {output.af} 2>>{log}
            """

    rule run_casper_gene_annot:
        input:
            matrix = SELECTED_COUNT_MATRIX
        output:
            gene_annot = f"results/{mat_specific_dataset}_output/casper_known_ref/gene_annotation_casper_{dataset}.tsv"
        params:
            helper_script = f"{workflow.basedir}/scripts/casper_helpers.R" # Match your helper file name
        log:
            f"logs/{mat_specific_dataset}/{mat_specific_dataset}_casper_gene_annot.log"
        benchmark:
            f"benchmarks/{mat_specific_dataset}/{mat_specific_dataset}_casper_gene_annot_benchmark.txt"
        threads: 1
        resources:
            mem_mb = 8000
        script:
            "scripts/casper_gene_annotations.R"

    rule run_casper_with_given_refs:
        input:
            matrix     = SELECTED_COUNT_MATRIX,
            annot      = RNA_BEST_ANNOTATION,
            ref_groups = f"data/{DATASET}_input/ref_groups.txt",
            #gene_annot = f"data/annotations/casper_gene_annotation_GRCh38.tsv",
            gene_annot = f"results/{mat_specific_dataset}_output/casper_known_ref/gene_annotation_casper_{dataset}.tsv",
            af         = f"results/{mat_specific_dataset}_output/casper_known_ref/{dataset}_BAFExtract/{dataset}_BAFExtract.af"
        output:
            casper_cellmatrix        = f"results/{mat_specific_dataset}_output/casper_known_ref/{dataset}_casper_cell_matrix.tsv",
            casper_pseudobulk        = f"results/{mat_specific_dataset}_output/casper_known_ref/{dataset}_casper_pseudobulk_aggregate.RDS",
            casper_clusters          = f"results/{mat_specific_dataset}_output/casper_known_ref/{dataset}_casper_hclust.RDS",
            casper_plot_density      = f"results/{mat_specific_dataset}_output/casper_known_ref/{dataset}_casper_densities.pdf",
            casper_plot_large_events = f"results/{mat_specific_dataset}_output/casper_known_ref/{dataset}_casper_large_events.png",
            casper_plot_heatmap      = f"results/{mat_specific_dataset}_output/casper_known_ref/{dataset}_casper_heatmap.png",
            casper_plot_baf          = f"results/{mat_specific_dataset}_output/casper_known_ref/{dataset}_casper_baf.png"
        log:
            f"logs/{mat_specific_dataset}/{mat_specific_dataset}_casper.log"
        benchmark:
            f"benchmarks/{mat_specific_dataset}/{mat_specific_dataset}_casper_benchmark.txt"
        threads: 1
        resources:
            mem_mb = 64000
        params:
            segment_gamma = 7,
            time = "48:00:00"
        script:
            "scripts/casper.R"

    rule evaluate_casper_with_given_refs:
        input:
            ground_truth      = f"data/{DATASET}_ginkgo_groundtruth/wgs_results_formated.csv",
            casper_cellmatrix = f"results/{mat_specific_dataset}_output/casper_known_ref/{DATASET}_casper_cell_matrix.tsv",
            gene_pos          = GENE_POS_FILE,
            samp_annot = ORI_CELL_ANNOTATION, dna_annot = DNA_CELL_ANNOTATION, rna_annot = RNA_CELL_ANNOTATION,
            chrom_pos         = CHROM_ARM_POS,
        output:
            results = f"results/{mat_specific_dataset}_output/evaluation/bench_{mat_specific_dataset}_casper_with_preclassified_cells.tsv"
        log:
            f"logs/{mat_specific_dataset}/{mat_specific_dataset}_evaluate_casper_with_preclassified_cells.log"
        benchmark:
            f"benchmarks/{mat_specific_dataset}/{mat_specific_dataset}_evaluate_casper_with_preclassified_cells_benchmark.txt"
        threads: 1
        resources:
            mem_mb = 16000
        shell:
            r"""
            set -euo pipefail
            python3 {workflow.basedir}/scripts/evaluate_caller_vs_ginkgo.py \
                --ground-truth {input.ground_truth} \
                --caller-result {input.casper_cellmatrix} \
                --caller-name casper \
                --gene-pos {input.gene_pos} \
                --sample-annotation {input.samp_annot} --dna-annotation {input.dna_annot} --rna-annotation {input.rna_annot} \
                --output {output.results} \
                --chrom-arm-pos {input.chrom_pos} \
                2>{log}
            """

# ==============================================================================
# Numbat: https://github.com/kharchenkolab/numbat
#   requires scRNA BAM for BAF extraction
# ==============================================================================

if MODE == "fastq" or MODE == "bam":

    rule numbat_prepare_bam_list:
        input:
            bams = [ALL_SCRNA_BAM_OF[c] for c in ALL_CELL_IDS]
        output:
            bam_list   = f"results/{mat_specific_dataset}_output/numbat_prep/list_bam_files_fullpath.txt",
            cell_names = f"results/{mat_specific_dataset}_output/numbat_prep/matching_sample_names.txt"
        log:
            f"logs/{mat_specific_dataset}/{mat_specific_dataset}_numbat_bam_list.log"
        threads: 1
        run:
            import os
            os.makedirs(os.path.dirname(output.bam_list), exist_ok=True)
            with open(output.bam_list, "w") as f:
                for c in ALL_CELL_IDS:
                    f.write(os.path.abspath(ALL_SCRNA_BAM_OF[c]) + "\n")
            with open(output.cell_names, "w") as f:
                for c in ALL_CELL_IDS:
                    f.write(c + "\n")

    rule numbat_preprocessing:
        input:
            bam_list   = f"results/{mat_specific_dataset}_output/numbat_prep/list_bam_files_fullpath.txt",
            cell_names = f"results/{mat_specific_dataset}_output/numbat_prep/matching_sample_names.txt",
            snp_vcf    = NUMBAT_SNP_VCF,
            eagle_gmap = NUMBAT_EAGLE_GMAP
        output:
            df_allele = f"results/{mat_specific_dataset}_output/numbat_prep/{dataset}_allele_counts.tsv.gz"
        log:
            f"logs/{mat_specific_dataset}/{mat_specific_dataset}_numbat_preprocessing.log"
        benchmark:
            f"benchmarks/{mat_specific_dataset}/{mat_specific_dataset}_numbat_preprocessing_benchmark.txt"
        threads: 16
        resources:
            mem_mb = 32000
        params:
            time      = "24:00:00",
            ref_panel = NUMBAT_REF_PANEL,
            eagle_bin = EAGLE_BIN,
            out_dir   = f"results/{mat_specific_dataset}_output/numbat_prep/",
            label     = dataset
        shell:
            r"""
            set -euo pipefail
            Rscript {workflow.basedir}/scripts/pileup_and_phase.R \
                --label {params.label} \
                --samples {params.label} \
                --bams {input.bam_list} \
                --barcodes {input.cell_names} \
                --outdir {params.out_dir} \
                --gmap {input.eagle_gmap} \
                --eagle {params.eagle_bin} \
                --snpvcf {input.snp_vcf} \
                --paneldir {params.ref_panel} \
                --smartseq \
                --ncores {threads} > {log} 2>&1
            """

    rule run_numbat_without_given_refs:
        input:
            count_mat = SELECTED_COUNT_MATRIX,
            df_allele = f"results/{mat_specific_dataset}_output/numbat_prep/{dataset}_allele_counts.tsv.gz"
        output:
            cnv_expr = f"results/{mat_specific_dataset}_output/numbat_unknown_ref/gexp_roll_wide.tsv.gz"
        log:
            f"logs/{mat_specific_dataset}/{mat_specific_dataset}_numbat_without_preclassified_cells.log"
        benchmark:
            f"benchmarks/{mat_specific_dataset}/{mat_specific_dataset}_numbat_without_preclassified_cells_benchmark.txt"
        threads: 1
        resources:
            mem_mb = 32000
        params:
            time = "24:00:00"
        script:
            "scripts/numbat_woref.R"

    rule evaluate_numbat_without_given_refs:
        input:
            ground_truth = f"data/{DATASET}_ginkgo_groundtruth/wgs_results_formated.csv",
            numbat_expr  = f"results/{mat_specific_dataset}_output/numbat_unknown_ref/gexp_roll_wide.tsv.gz",
            gene_pos     = GENE_POS_FILE,
            samp_annot = ORI_CELL_ANNOTATION, dna_annot = DNA_CELL_ANNOTATION, rna_annot = RNA_CELL_ANNOTATION,
        output:
            results = f"results/{mat_specific_dataset}_output/evaluation/bench_{mat_specific_dataset}_numbat_without_preclassified_cells.tsv"
        log:
            f"logs/{mat_specific_dataset}/{mat_specific_dataset}_evaluate_numbat_without_preclassified_cells.log"
        benchmark:
            f"benchmarks/{mat_specific_dataset}/{mat_specific_dataset}_evaluate_numbat_without_preclassified_cells_benchmark.txt"
        threads: 1
        resources:
            mem_mb = 16000
        shell:
            r"""
            set -euo pipefail
            python3 {workflow.basedir}/scripts/evaluate_caller_vs_ginkgo.py \
                --ground-truth {input.ground_truth} \
                --caller-result {input.numbat_expr} \
                --caller-name numbat_predict \
                --gene-pos {input.gene_pos} \
                --sample-annotation {input.samp_annot} --dna-annotation {input.dna_annot} --rna-annotation {input.rna_annot} \
                --output {output.results} \
                2>{log}
            """

if (MODE == "fastq" or MODE == "bam") and always_has_ref_cells:

    rule run_numbat_with_given_refs:
        input:
            # <FIX URL=https://chat.deepseek.com/a/chat/s/3b809dd5-1e42-4e56-a19b-507eabe4cd31> with_header </FIX>
            count_mat  = SELECTED_COUNT_MATRIX,
            annot      = RNA_BEST_ANNOTATION,
            ref_groups = f"data/{DATASET}_input/ref_groups.txt",
            df_allele  = f"results/{mat_specific_dataset}_output/numbat_prep/{dataset}_allele_counts.tsv.gz"
        output:
            cnv_expr = f"results/{mat_specific_dataset}_output/numbat_known_ref/gexp_roll_wide.tsv.gz"
        log:
            f"logs/{mat_specific_dataset}/{mat_specific_dataset}_numbat.log"
        benchmark:
            f"benchmarks/{mat_specific_dataset}/{mat_specific_dataset}_numbat_benchmark.txt"
        threads: 1
        resources:
            mem_mb = 32000
        params:
            time      = "48:00:00",
            gamma     = "5",
            min_LLR   = "5",
            min_cells = "10"
        script:
            "scripts/numbat.R"

    rule evaluate_numbat_with_given_refs:
        input:
            ground_truth = f"data/{DATASET}_ginkgo_groundtruth/wgs_results_formated.csv",
            numbat_expr  = f"results/{mat_specific_dataset}_output/numbat_known_ref/gexp_roll_wide.tsv.gz",
            gene_pos     = GENE_POS_FILE,
            samp_annot = ORI_CELL_ANNOTATION, dna_annot = DNA_CELL_ANNOTATION, rna_annot = RNA_CELL_ANNOTATION,
        output:
            results = f"results/{mat_specific_dataset}_output/evaluation/bench_{mat_specific_dataset}_numbat_with_preclassified_cells.tsv"
        log:
            f"logs/{mat_specific_dataset}/{mat_specific_dataset}_evaluate_numbat_with_preclassified_cells.log"
        benchmark:
            f"benchmarks/{mat_specific_dataset}/{mat_specific_dataset}_evaluate_numbat_with_preclassified_cells_benchmark.txt"
        threads: 1 
        resources:
            mem_mb = 16000
        shell:
            r"""
            set -euo pipefail
            python3 {workflow.basedir}/scripts/evaluate_caller_vs_ginkgo.py \
                --ground-truth {input.ground_truth} \
                --caller-result {input.numbat_expr} \
                --caller-name numbat \
                --gene-pos {input.gene_pos} \
                --sample-annotation {input.samp_annot} --dna-annotation {input.dna_annot} --rna-annotation {input.rna_annot} \
                --output {output.results} \
                2>{log}
            """

# ==============================================================================
# Dataset-level descriptive / confounder metrics
#
# Tumor/normal is summarised under BOTH labelings, plus their agreement:
#   (1) "sample" = author/config labels   -> ORI_CELL_ANNOTATION
#                  (data/{DATASET}_input/sample_annotation_1.txt,
#                   written by rule create_sample_annotation_1)
#   (2) "dna"    = Ginkgo ground-truth labels -> DNA_CELL_ANNOTATION
#                  (data/{dataset}_ginkgo_groundtruth/dna_cell_annotation.txt,
#                   written by separate_tumor_normal_from_ginkgo_segcopy.py via
#                   rule format_ginkgo_ground_truth)
#
# Reads (declared as real inputs so this rule runs AFTER alignment + Ginkgo,
# instead of the script string-munging the config and racing the DAG):
#   - merged YAML config(s)         (celltype labels -> cell counts)
#   - both annotation files         (the two tumor/normal labelings)
#   - per-cell *.bam.stats          (already produced by the alignment rules)
#   - lifted Ginkgo SegCopy_grch38  (ploidy / CNV burden)
# ==============================================================================
# The metrics script needs the merged config on disk. configfile paths are not
# exposed as a list in older Snakemake, so fall back to workflow.configfiles.
_METRICS_CONFIG_PATHS = list(getattr(workflow, "configfiles", []) or [])

rule compute_dataset_metrics:
    input:
        segcopy      = f"results/{dataset}_ginkgo/output/SegCopy_grch38.tsv",
        sample_annot = ORI_CELL_ANNOTATION,   # (1) author/config labeling
        dna_annot    = DNA_CELL_ANNOTATION,    # (2) Ginkgo ground-truth labeling
        dna_stats    = [f"results/{dataset}_bams/dna/{c}_hg19.bam.stats"
                        for c in ALL_CELL_IDS],
        rna_stats    = [f"results/{dataset}_bams/rna/all_cells_grch38_{c}.bam.stats"
                        for c in ALL_CELL_IDS],
    output:
        metrics            = f"results/{mat_specific_dataset}_output/evaluation/dataset_metrics.tsv",
        per_cell           = f"results/{mat_specific_dataset}_output/evaluation/per_cell_metrics.tsv",
        agreement          = f"results/{mat_specific_dataset}_output/evaluation/annotation_agreement.tsv",
        discordant         = f"results/{mat_specific_dataset}_output/evaluation/annotation_discordant_cells.tsv",
        cnv_event_sizes    = f"results/{mat_specific_dataset}_output/evaluation/cnv_event_sizes.tsv",
    log:
        f"logs/{mat_specific_dataset}/{mat_specific_dataset}_compute_dataset_metrics.log"
    threads: 1
    resources:
        mem_mb = 4000
    params:
        config_paths   = _METRICS_CONFIG_PATHS,
        dataset        = dataset,           # stem for results/{dataset}_bams/...
        results_prefix = "",                # run from the Snakemake workdir
        focal_max_bp   = 3_000_000,
        HAS_REF_CELLS  = HAS_REF_CELLS,
    script:
        "scripts/compute_dataset_metrics.py"



