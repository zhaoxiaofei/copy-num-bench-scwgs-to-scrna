            f"logs/evaluate_copykat_without_preclassified_cells_{DATASET}.log"
        benchmark:
            f"benchmarks/evaluate_copykat_without_preclassified_cells_{DATASET}.txt"
        threads: 1
        resources:
            mem_mb = 16000
        run:
            import subprocess, sys, os
