if MODE == "bam" and HAS_REF_CELLS:

    rule casper_merge_scrna_bams:
        input:
            bams = [ALL_SCRNA_BAM_OF[c] for c in ALL_CELL_IDS]
        output:
            merged = f"results/output_{dataset}/casper_known_ref/merged.bam",
            merged_bai = f"results/output_{dataset}/casper_known_ref/merged.bam.bai"
        log:
            f"logs/casper_merge_bams_{dataset}.log"
        threads: 4
        resources:
            mem_mb = 8000
        shell:
            r"""
            set -euo pipefail
            mkdir -p $(dirname {output.merged})
            samtools merge -@ {threads} -f {output.merged} {input.bams} 2>{log}
            samtools index {output.merged} 2>>{log}
            """

    rule run_BAFextract_casper:
        input:
            bam_file = f"results/output_{dataset}/casper_known_ref/merged.bam"
        output:
            out_dir = directory(f"results/output_{dataset}/casper_known_ref/{dataset}_bins_BAFExtract"),
            af      = f"results/output_{dataset}/casper_known_ref/{dataset}_BAFExtract/{dataset}_BAFExtract.af"
        log:
            f"logs/casper_preprocess_{dataset}.log"
        benchmark:
            f"benchmarks/casper_preprocess_{dataset}_benchmark.txt"
        threads: 1
        resources:
            mem_mb = 24000
        params:
            genome_list = BAFEXTRACT_GENOME_LIST,
            genome      = BAFEXTRACT_GENOME,
            bafextract  = BAFEXTRACT_BIN
        shell:
            r"""
            set -euo pipefail
            mkdir -p {output.out_dir}
            mkdir -p $(dirname {output.af})
            samtools view {input.bam_file} \
                | {params.bafextract} -generate_compressed_pileup_per_SAM stdin \
                    {params.genome_list} {output.out_dir} 50 0 2>{log}
            {params.bafextract} -get_SNVs_per_pileup \
                {params.genome_list} {output.out_dir} {params.genome} 20 4 0.1 {output.af} 2>>{log}
            """

    rule run_casper_gene_annot:
        input:
            matrix = f"data/input_{dataset}/count_matrix.txt"
        output:
            gene_annot = f"results/output_{dataset}/casper_known_ref/gene_annotation_casper_{dataset}.tsv"
        params:
            helper_script = f"{workflow.basedir}/scripts/casper_helpers.R" # Match your helper file name
        log:
            f"logs/casper_gene_annot_{dataset}.log"
        benchmark:
            f"benchmarks/casper_gene_annot_{dataset}_benchmark.txt"
        threads: 1
        resources:
            mem_mb = 8000
        script:
            "scripts/casper_gene_annotations.R"

    rule run_casper_with_given_refs:
        input:
            matrix     = f"data/input_{dataset}/count_matrix.txt",
            annot      = f"data/input_{dataset}/sample_annotation.txt",
            ref_groups = f"data/input_{dataset}/ref_groups.txt",
            #gene_annot = f"data/annotations/casper_gene_annotation_GRCh38.tsv",
            gene_annot = f"results/output_{dataset}/casper_known_ref/gene_annotation_casper_{dataset}.tsv",
            af         = f"results/output_{dataset}/casper_known_ref/{dataset}_BAFExtract/{dataset}_BAFExtract.af"
        output:
            casper_cellmatrix        = f"results/output_{dataset}/casper_known_ref/{dataset}_casper_cell_matrix.tsv",
            casper_pseudobulk        = f"results/output_{dataset}/casper_known_ref/{dataset}_casper_pseudobulk_aggregate.RDS",
            casper_clusters          = f"results/output_{dataset}/casper_known_ref/{dataset}_casper_hclust.RDS",
            casper_plot_density      = f"results/output_{dataset}/casper_known_ref/{dataset}_casper_densities.pdf",
            casper_plot_large_events = f"results/output_{dataset}/casper_known_ref/{dataset}_casper_large_events.png",
            casper_plot_heatmap      = f"results/output_{dataset}/casper_known_ref/{dataset}_casper_heatmap.png",
            casper_plot_baf          = f"results/output_{dataset}/casper_known_ref/{dataset}_casper_baf.png"
        log:
            f"logs/casper_{dataset}.log"
        benchmark:
            f"benchmarks/casper_{dataset}_benchmark.txt"
        threads: 1
        resources:
            mem_mb = 64000
        params:
            segment_gamma = 7,
            time = "48:00:00"
        script:
            "scripts/casper.R"

# ==============================================================================
# Numbat: https://github.com/kharchenkolab/numbat
#   requires scRNA BAM for BAF extraction
# ==============================================================================

if MODE == "bam":

    rule numbat_prepare_bam_list:
        input:
            bams = [ALL_SCRNA_BAM_OF[c] for c in ALL_CELL_IDS]
        output:
            bam_list   = f"results/output_{dataset}/numbat_prep/list_bam_files_fullpath.txt",
            cell_names = f"results/output_{dataset}/numbat_prep/matching_sample_names.txt"
        log:
            f"logs/numbat_bam_list_{dataset}.log"
        threads: 1
        run:
            import os
            os.makedirs(os.path.dirname(output.bam_list), exist_ok=True)
            with open(output.bam_list, "w") as f:
                for c in ALL_CELL_IDS:
                    f.write(os.path.abspath(ALL_SCRNA_BAM_OF[c]) + "\n")
            with open(output.cell_names, "w") as f:
                for c in ALL_CELL_IDS:
                    f.write(c + "\n")

    rule numbat_preprocessing:
        input:
            bam_list   = f"results/output_{dataset}/numbat_prep/list_bam_files_fullpath.txt",
            cell_names = f"results/output_{dataset}/numbat_prep/matching_sample_names.txt",
            snp_vcf    = NUMBAT_SNP_VCF,
            eagle_gmap = NUMBAT_EAGLE_GMAP
        output:
            df_allele = f"results/output_{dataset}/numbat_prep/{dataset}_allele_counts.tsv.gz"
        log:
            f"logs/numbat_preprocessing_{dataset}.log"
        benchmark:
            f"benchmarks/numbat_preprocessing_{dataset}_benchmark.txt"
        threads: 4
        resources:
            mem_mb = 32000
        params:
            time      = "24:00:00",
            ref_panel = NUMBAT_REF_PANEL,
            eagle_bin = EAGLE_BIN,
            out_dir   = f"results/output_{dataset}/numbat_prep/",
            label     = dataset
        shell:
            r"""
            set -euo pipefail
            Rscript {workflow.basedir}/scripts/pileup_and_phase.R \
                --label {params.label} \
                --samples {params.label} \
                --bams {input.bam_list} \
                --barcodes {input.cell_names} \
                --outdir {params.out_dir} \
                --gmap {input.eagle_gmap} \
                --eagle {params.eagle_bin} \
                --snpvcf {input.snp_vcf} \
                --paneldir {params.ref_panel} \
                --smartseq \
                --ncores {threads} > {log} 2>&1
            """

    rule run_numbat_without_given_refs:
        input:
            count_mat = "data/input_{dataset}/count_matrix.txt",
            df_allele = f"results/output_{dataset}/numbat_prep/{dataset}_allele_counts.tsv.gz"
        output:
            cnv_expr = "results/output_{dataset}/numbat_unknown_ref/gexp_roll_wide.tsv.gz"
        log:
            "logs/numbat_without_preclassified_cells_{dataset}.log"
        benchmark:
            "benchmarks/numbat_without_preclassified_cells_{dataset}_benchmark.txt"
        threads: 1
        resources:
            mem_mb = 32000
        params:
            time = "24:00:00"
        script:
            "scripts/numbat_woref.R"

if MODE == "bam" and HAS_REF_CELLS:

    rule run_numbat_with_given_refs:
        input:
            # <FIX URL=https://chat.deepseek.com/a/chat/s/3b809dd5-1e42-4e56-a19b-507eabe4cd31> with_header </FIX>
            count_mat  = f"data/input_{dataset}/count_matrix.txt",
