                    --ground-truth {input.ground_truth} \
                    --caller-result {input.copykat} \
                    --caller-name copykat_predict \
                    --gene-pos {input.gene_pos} \
                    --sample-annotation {input.samp_annot} \
                    --output {output.results} \
                    2>{log}
