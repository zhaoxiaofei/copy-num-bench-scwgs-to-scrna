### Modified pipeline to benchmark scRNA-seq CNV callers using paired scWGS/scRNA
# data. Ground truth is derived from scWGS via Ginkgo, then lifted over from
# hg19 to GRCh38, and compared against CNV calls from scRNA-seq callers.
#
# --- MODE 1 (FastQ-based): config["cellname_celltype_DNAseqFQ1_DNAseqFQ2_RNAseqFQ1_RNAseqFQ2_tup_list"] ---
#   A list of 6-element lists: [[cell_id, celltype, DNAseqFQ1, DNAseqFQ2, RNAseqFQ1, RNAseqFQ2], ...]
#   - celltype determines whether a cell is treated as normal/reference or tumor:
#     Reference celltypes (case-insensitive): N, Normal, Control, Ctrl, Reference,
#       Ref, Diploid, BL, Lymphocyte, Lymphocite, Blood
#     All other celltype strings are treated as tumor/case cells.
#   - DNA-seq FastQ files are aligned to UCSC hg19 using BWA MEM
#   - RNA-seq FastQ files are aligned to GRCh38 using STAR with SOLO
#   - scWGS_scRNA_prefix is prepended to all FastQ file paths (filepath suffixes)
#   - If FQ2 is not available, use "-" or "." or "" as the value
#   A count matrix is generated from the scRNA BAMs via featureCounts.
#
# --- MODE 2 (Matrix-based): config["scWGS_matrix_pairs"] ---
#   A 2-element list: [ [[cell_id, scWGS_bam], ...], matrix_filename ]
#   - The first element is a list of pairs, each pair being [cell_id, scWGS_bam].
#     cell_id must match a column header in the matrix file.
#     scWGS BAMs are aligned to UCSC hg19.
#   - The second element is the path to an RNA-seq transcript count matrix file
#     (genes as rows, cell IDs as tab-separated column headers).
#   In this mode, featureCounts is skipped; the provided matrix is used directly.
#
# Exactly one of cellname_celltype_DNAseqFQ1_DNAseqFQ2_RNAseqFQ1_RNAseqFQ2_tup_list or scWGS_matrix_pairs must be provided.
#
# Optional config keys:
#   config["GINKGO_SH"]       - path to ginkgo.sh (default: /mnt/d/code/ginkgo/cli/ginkgo.sh)
#   config["ginkgo_genome"]   - ginkgo genome name (default: "hg19")
#   config["ginkgo_binning"]  - ginkgo binning scheme (default: "variable_500000_150_bwa")
#   config["liftover_chain"]  - path to hg19ToHg38.over.chain.gz
#   config["liftover_bin"]    - path to liftOver binary (default: "liftOver")
#   config["gtf_grch38"]      - path to GRCh38 GTF for featureCounts (FastQ mode only)
#   config["gene_pos_grch38"] - path to gene position file for inferCNV (hg38_gencode_v27.txt)
#   config["chrom_arm_pos"]   - path to chromosome arm positions (chromosome_arm_positions_grch38.txt)
#   config["ref_matrix_cell_ids"] - optional list of cell IDs in the matrix to use as
#                                   reference/normal cells (matrix mode only)
#   config["bafextract_bin"]         - path to BAFExtract binary (CaSpER)
#   config["bafextract_genome_list"] - path to BAFExtract hg38 genome list file
#   config["bafextract_genome"]      - path to BAFExtract hg38 genome directory/prefix
#   config["numbat_snp_vcf"]    - 1000G SNP VCF (hg38) for Numbat
#   config["numbat_eagle_gmap"] - Eagle genetic map (hg38) for Numbat
#   config["numbat_ref_panel"]  - 1000G reference panel dir for Numbat
#   config["eagle_bin"]         - path to eagle binary (Numbat)
#
#   # FastQ mode specific reference genome config:
#   config["hg19_fasta"]       - path to hg19 FASTA reference for BWA (default: /stor/zxf/cnv/refs/hg19.fa)
#   config["grch38_fasta"]     - path to GRCh38 FASTA reference for BWA (default: /stor/zxf/cnv/refs/grch38/GRCh38_masked_v2_decoy_gene.fasta)
#   config["star_hg19_dir"]    - path to STAR genome index dir for hg19
#   config["star_hg19_gtf"]   - path to GTF annotation for hg19
#   config["star_grch38_dir"] - path to STAR genome index dir for GRCh38
#   config["star_grch38_gtf"] - path to GTF annotation for GRCh38
#   config["bwa_threads"]      - BWA-MEM threads (default: 4)
#   config["star_threads"]    - STAR threads (default: 4)
#   config["sort_threads"]     - samtools sort threads (default: 4)
#   config["sjdb_overhang"]    - STAR sjdbOverhang (default: 149)
# ==============================================================================

import logging
import os
import hashlib

# ---------------------------------------------------------------------------
# Helper: classify celltype as reference/normal or tumor
# ---------------------------------------------------------------------------

_REF_CELLTYPES = {
    "n", "normal", "control", "ctrl", "reference", "ref",
    "diploid", "bl", "lymphocyte", "lymphocite", "blood",
}

# Celltype strings that carry NO tumor/normal information: the config declines
# to label the cell, deferring the call to the DNA (Ginkgo) ground truth.
_UNKNOWN_CELLTYPES = {"unknown", "unk", "na", "n/a", "", "-", "."}

def _is_ref_celltype(celltype):
    """Return True if celltype string denotes a normal/reference (diploid control) cell."""
    return str(celltype).strip().lower() in _REF_CELLTYPES

def _is_unknown_celltype(celltype):
    """Return True if celltype string carries no tumor/normal label (defer to DNA)."""
    return str(celltype).strip().lower() in _UNKNOWN_CELLTYPES


# ---------------------------------------------------------------------------
# Determine mode and parse configuration
# ---------------------------------------------------------------------------

_has_fastq_mode    = "cellname_celltype_DNAseqFQ1_DNAseqFQ2_RNAseqFQ1_RNAseqFQ2_tup_list" in config
_has_matrix_mode = "scWGS_matrix_pairs" in config

assert _has_fastq_mode or _has_matrix_mode, (
    "Config must provide either 'cellname_celltype_DNAseqFQ1_DNAseqFQ2_RNAseqFQ1_RNAseqFQ2_tup_list' (FastQ mode) "
    "or 'scWGS_matrix_pairs' (matrix mode)."
)
assert not (_has_fastq_mode and _has_matrix_mode), (
    "Config must provide exactly one of 'cellname_celltype_DNAseqFQ1_DNAseqFQ2_RNAseqFQ1_RNAseqFQ2_tup_list' or "
    "'scWGS_matrix_pairs', not both."
)

MODE = "matrix" if _has_matrix_mode else "fastq"

# ---------------------------------------------------------------------------
# Shared optional config
# ---------------------------------------------------------------------------

GINKGO_ENV     = config.get("GINKGO_ENV",      "ginkgo_env1")
GINKGO_SH      = config.get("GINKGO_SH",       config.get("ginkgo_sh", "/mnt/d/code/ginkgo/cli/ginkgo.sh"))
GINKGO_GENOME  = config.get("ginkgo_genome",   "hg19")
GINKGO_BINNING = config.get("ginkgo_binning",  "variable_500000_150_bwa")
LIFTOVER_CHAIN = config.get("liftover_chain",  "data/annotations/hg19ToHg38.over.chain.gz")
LIFTOVER_BIN   = config.get("liftover_bin",    "liftOver")
# GTF_GRCH38     = config.get("gtf_grch38",      "data/annotations/gencode.v27.annotation.gtf") # later use the GTF from STAR
GENE_POS_FILE  = config.get("gene_pos_grch38", "data/annotations/hg38_gencode_v27.txt")
GENE_POS_FILE_HG19  = config.get("gene_pos_hg19", "data/annotations/gencode_v19_gene_pos.txt")
CHROM_ARM_POS  = config.get("chrom_arm_pos",   "data/annotations/chromosome_arm_positions_grch38.txt")

# CaSpER / BAFExtract
BAFEXTRACT_BIN         = config.get("bafextract_bin",         "tools/BAFExtract/bin/BAFExtract")
BAFEXTRACT_GENOME_LIST = config.get("bafextract_genome_list", "data/annotations/genome_input_BAFExtract_hg38/hg38_genome_list")
BAFEXTRACT_GENOME      = config.get("bafextract_genome",      "data/annotations/genome_input_BAFExtract_hg38/hg38")

# Numbat / Eagle
NUMBAT_SNP_VCF    = config.get("numbat_snp_vcf",    "data/annotations/genome1K.phase3.SNP_AF5e2.chr1toX.hg38.vcf.gz")
NUMBAT_EAGLE_GMAP = config.get("numbat_eagle_gmap", "data/annotations/genetic_map_hg38_withX.txt.gz")
NUMBAT_REF_PANEL  = config.get("numbat_ref_panel",  "data/annotations/1000G_hg38")
EAGLE_BIN         = config.get("eagle_bin",         "tools/Eagle_v2.4.1/eagle")

DATASET_NAME = config.get('dataset', "scWGS_scRNA")
DATASET_PREFIX = config.get('dataset_prefix', "") # ad-hoc
DATASET_SUFFIX = config.get('dataset_suffix', "") # ad-hoc
DATASET = DATASET_PREFIX + DATASET_NAME + DATASET_SUFFIX
dataset = DATASET

mat_src = config.get('mat_src', 'star-solo-genefull') # featurecounts or star-solo-gene
assert mat_src in ['star-solo-gene', 'star-solo-genefull', 'featurecounts']

if MODE == "fastq":
    if mat_src == 'star-solo-genefull':
        SELECTED_COUNT_MATRIX = f"results/{dataset}_bams/rna/cell_by_gene_GeneFull.tsv"
        mat_specific_dataset = f"{dataset}_solo-genefull"
    if mat_src == 'star-solo-gene':
        SELECTED_COUNT_MATRIX = f"results/{dataset}_bams/rna/cell_by_gene_Gene.tsv"
        mat_specific_dataset = f"{dataset}_solo-gene"
    if mat_src == 'featurecounts':
        SELECTED_COUNT_MATRIX = f"data/{DATASET}_input/featurecounts_matrix.txt"
        mat_specific_dataset = f"{dataset}_feature-counts"
else:
    SELECTED_COUNT_MATRIX = f"data/{DATASET}_input/counts_matrix.txt"
    mat_specific_dataset = f"{dataset}_3rdparty-counts"

# ---------------------------------------------------------------------------
# FastQ mode specific reference genome config
# ---------------------------------------------------------------------------

# BWA-MEM constants
HG19_FASTA = config.get("hg19_fasta", "/stor/zxf/cnv/refs/hg19.fa")
GRCH38_FASTA = config.get("grch38_fasta", "/stor/zxf/cnv/refs/grch38/GRCh38_masked_v2_decoy_gene.fasta")
BWA_MEM_K = 100 * 1000 * 1000  # 100M bases batch size

# STAR constants
STAR_DETERMINISTIC_ARGS = "--runRNGseed 0 --outSAMorder Paired"
STAR_LIMIT_BAM_SORT_RAM = 32 * 1000 * 1000 * 1000  # 6GB

# Thread defaults
BWA_THREADS = config.get("bwa_threads", 4)
STAR_THREADS = config.get("star_threads", 64)
SORT_THREADS = config.get("sort_threads", 4)
SJDB_OVERHANG = config.get("sjdb_overhang", 149)

# STAR index defaults
STAR_PREFIX = f"data/annotations"
STAR_HG19_DIR = config.get("star_hg19_dir", f"{STAR_PREFIX}/GRCh37_gencode_v19_CTAT_lib_Mar012021.plug-n-play/ctat_genome_lib_build_dir/ref_genome.fa.star.idx")
STAR_HG19_GTF = config.get("star_hg19_gtf", f"{STAR_PREFIX}/GRCh37_gencode_v19_CTAT_lib_Mar012021.plug-n-play/ctat_genome_lib_build_dir/ref_annot.gtf")
STAR_GRCH38_DIR = config.get("star_grch38_dir", f"{STAR_PREFIX}/GRCh38_gencode_v22_CTAT_lib_Mar012021.plug-n-play/ctat_genome_lib_build_dir/ref_genome.fa.star.idx")
STAR_GRCH38_GTF = config.get("star_grch38_gtf", f"{STAR_PREFIX}/GRCh38_gencode_v22_CTAT_lib_Mar012021.plug-n-play/ctat_genome_lib_build_dir/ref_annot.gtf")

GTF_GRCH38 = STAR_GRCH38_GTF

# ---------------------------------------------------------------------------
# Mode-specific configuration
# ---------------------------------------------------------------------------

FILE_PREFIX = config.get("scWGS_scRNA_prefix", "")
FILE_OVERRIDE_PREFIX = os.getenv('SCWGS_SCRNA_PREFIX_OVERRIDE')
if FILE_OVERRIDE_PREFIX: FILE_PREFIX = FILE_OVERRIDE_PREFIX

def _is_empty_fq(fq_value):
    """Check if FQ value is empty or a placeholder."""
    if fq_value is None:
        return True
    fq_str = str(fq_value).strip()
    return fq_str in ["", "-", "."]

if MODE == "fastq":
    # ---- FastQ mode ----
    CELL_RECORD_LIST = config["cellname_celltype_DNAseqFQ1_DNAseqFQ2_RNAseqFQ1_RNAseqFQ2_tup_list"]
    assert len(CELL_RECORD_LIST) > 0, "config['cellname_celltype_DNAseqFQ1_DNAseqFQ2_RNAseqFQ1_RNAseqFQ2_tup_list'] must be a non-empty list"
    for idx, rec in enumerate(CELL_RECORD_LIST):
        assert len(rec) == 6, (
            f"Each element of cellname_celltype_DNAseqFQ1_DNAseqFQ2_RNAseqFQ1_RNAseqFQ2_tup_list must have exactly 6 elements "
            f"[cell_id, celltype, DNAseqFQ1, DNAseqFQ2, RNAseqFQ1, RNAseqFQ2], but element {idx} has {len(rec)}"
        )

    _all_ids = [rec[0] for rec in CELL_RECORD_LIST]
    assert len(_all_ids) == len(set(_all_ids)), "Duplicate cell IDs detected"
   
    # If the config declines to label every cell (all "Unknown"), the tumor/normal
    # origin is not author-provided; defer entirely to the DNA (Ginkgo) annotation
    # written by scripts/separate_tumor_normal_from_ginkgo_segcopy.py. Otherwise,
    # trust the config's per-cell celltype labels.
    ALL_CONFIG_UNKNOWN = all(_is_unknown_celltype(rec[1]) for rec in CELL_RECORD_LIST)

    # Split into tumor vs reference based on celltype
    ALL_CELL_IDS = []
    REF_CELL_IDS = []
    TUM_CELL_IDS = []
    ALL_DNA_FQ1_OF = {}   # DNA-seq FastQ1 files
    ALL_DNA_FQ2_OF = {}   # DNA-seq FastQ2 files (may be None)
    ALL_RNA_FQ1_OF = {}   # RNA-seq FastQ1 files
    ALL_RNA_FQ2_OF = {}   # RNA-seq FastQ2 files (may be None)
    REF_DNA_FQ1_OF = {}   # Reference DNA-seq FastQ1 files
    REF_DNA_FQ2_OF = {}   # Reference DNA-seq FastQ2 files
    REF_RNA_FQ1_OF = {}   # Reference RNA-seq FastQ1 files
    REF_RNA_FQ2_OF = {}   # Reference RNA-seq FastQ2 files
    TUM_DNA_FQ1_OF = {}   # Tumor DNA-seq FastQ1 files
    TUM_DNA_FQ2_OF = {}   # Tumor DNA-seq FastQ2 files
    TUM_RNA_FQ1_OF = {}   # Tumor RNA-seq FastQ1 files
    TUM_RNA_FQ2_OF = {}   # Tumor RNA-seq FastQ2 files
    
    for rec in CELL_RECORD_LIST:
        cid, celltype = rec[0], rec[1]
        dna_fq1 = rec[2]
        dna_fq2 = None if _is_empty_fq(rec[3]) else rec[3]
        rna_fq1 = rec[4]
        rna_fq2 = None if _is_empty_fq(rec[5]) else rec[5]
        
        # Always add to ALL
        ALL_CELL_IDS.append(cid)
        ALL_DNA_FQ1_OF[cid] = FILE_PREFIX + dna_fq1
        ALL_DNA_FQ2_OF[cid] = (FILE_PREFIX + dna_fq2) if dna_fq2 else None
        ALL_RNA_FQ1_OF[cid] = FILE_PREFIX + rna_fq1
        ALL_RNA_FQ2_OF[cid] = (FILE_PREFIX + rna_fq2) if rna_fq2 else None
        
        if _is_ref_celltype(celltype):
            REF_CELL_IDS.append(cid)
            REF_DNA_FQ1_OF[cid] = FILE_PREFIX + dna_fq1
            REF_DNA_FQ2_OF[cid] = (FILE_PREFIX + dna_fq2) if dna_fq2 else None
            REF_RNA_FQ1_OF[cid] = FILE_PREFIX + rna_fq1
            REF_RNA_FQ2_OF[cid] = (FILE_PREFIX + rna_fq2) if rna_fq2 else None
        else:
            TUM_CELL_IDS.append(cid)
            TUM_DNA_FQ1_OF[cid] = FILE_PREFIX + dna_fq1
            TUM_DNA_FQ2_OF[cid] = (FILE_PREFIX + dna_fq2) if dna_fq2 else None
            TUM_RNA_FQ1_OF[cid] = FILE_PREFIX + rna_fq1
            TUM_RNA_FQ2_OF[cid] = (FILE_PREFIX + rna_fq2) if rna_fq2 else None
        
    assert len(TUM_CELL_IDS) > 0, (
        "At least one tumor/case cell is required. All cells were classified as "
        "reference/normal based on their celltype (and none were 'Unknown')."
    )

    # Matrix file path is not used in FastQ mode
    INPUT_MATRIX_FILE = None

else:
    # ---- Matrix mode ----

    # No celltype annotations are provided; treat all as "Unknown".
    # This will trigger DNA-derived (i.e., ground-truth) cell annotation and reference-cell identification.
    ALL_CONFIG_UNKNOWN = True

    _matrix_cfg = config["scWGS_matrix_pairs"]
    assert len(_matrix_cfg) == 2, (
        "config['scWGS_matrix_pairs'] must be a 2-element list: "
        "[list_of_[cell_id, scWGS_bam], matrix_filename]"
    )

    _cell_bam_pairs = _matrix_cfg[0]
    INPUT_MATRIX_FILE = _matrix_cfg[1]

    assert isinstance(_cell_bam_pairs, list) and len(_cell_bam_pairs) > 0, (
        "First element of scWGS_matrix_pairs must be a non-empty list of "
        "[cell_id, scWGS_bam] pairs."
    )
    assert isinstance(INPUT_MATRIX_FILE, str) and len(INPUT_MATRIX_FILE) > 0, (
        "Second element of scWGS_matrix_pairs must be a non-empty matrix file path."
    )

    for idx, pair in enumerate(_cell_bam_pairs):
        assert len(pair) == 2, (
            f"Each element of the cell/BAM list must have exactly 2 elements "
            f"[cell_id, scWGS_bam], but element {idx} has {len(pair)}"
        )

    ALL_CELL_IDS = [str(p[0]) for p in _cell_bam_pairs]
    #REF_CELL_IDS = [str(p[0]) for p in _cell_bam_pairs if _is_ref_celltype(p[1])]
    #TUM_CELL_IDS = [str(p[0]) for p in _cell_bam_pairs if not _is_ref_celltype(p[1])]
    REF_CELL_IDS = []
    TUM_CELL_IDS = ALL_CELL_IDS
    assert len(ALL_CELL_IDS) == len(set(ALL_CELL_IDS)), (
        "Duplicate cell IDs detected in scWGS_matrix_pairs"
    )

    ALL_SCWGS_BAM_OF = {str(p[0]): (FILE_PREFIX + p[1]) for p in _cell_bam_pairs}
    #REF_SCWGS_BAM_OF = {str(p[0]): (FILE_PREFIX + p[1]) for p in _cell_bam_pairs if _is_ref_celltype(p[1])}
    #TUM_SCWGS_BAM_OF = {str(p[0]): (FILE_PREFIX + p[1]) for p in _cell_bam_pairs if not _is_ref_celltype(p[1])}
    REF_SCWGS_BAM_OF = {}
    TUM_SCWGS_BAM_OF = ALL_SCWGS_BAM_OF

    ALL_SCRNA_BAM_OF = {}
    REF_SCRNA_BAM_OF = {}
    TUM_SCRNA_BAM_OF = {}

HAS_REF_CELLS = (not ALL_CONFIG_UNKNOWN) and (len(REF_CELL_IDS) >= 10)

# ---------------------------------------------------------------------------
# Wildcard constraints
# ---------------------------------------------------------------------------

wildcard_constraints:
    cell = "[A-Za-z0-9_-]+",

# ---------------------------------------------------------------------------
# Default target
# ---------------------------------------------------------------------------

always_has_ref_cells = 1

def _default_targets():
    targets = []
    targets.append(f"results/{mat_specific_dataset}_output/evaluation/bench_{mat_specific_dataset}_infercna_without_preclassified_cells.tsv")
    targets.append(f"results/{mat_specific_dataset}_output/evaluation/bench_{mat_specific_dataset}_infercna_hg19_without_preclassified_cells.tsv")
    targets.append(f"results/{mat_specific_dataset}_output/evaluation/bench_{mat_specific_dataset}_copykat_without_preclassified_cells.tsv")
    targets.append(f"results/{mat_specific_dataset}_output/evaluation/bench_{mat_specific_dataset}_copykat_cellline_without_preclassified_cells.tsv")
    targets.append(f"results/{mat_specific_dataset}_output/evaluation/bench_{mat_specific_dataset}_scevan_without_preclassified_cells.tsv")
    targets.append(f"results/{mat_specific_dataset}_output/evaluation/bench_{mat_specific_dataset}_CONICSmat_without_preclassified_cells.tsv")
    if MODE == "fastq" or MODE == "bam":
        targets.append(f"results/{mat_specific_dataset}_output/evaluation/bench_{mat_specific_dataset}_numbat_without_preclassified_cells.tsv")
    if always_has_ref_cells:
        # infercna evaluation target (only runs with reference cells)
        targets.append(f"results/{mat_specific_dataset}_output/evaluation/bench_{mat_specific_dataset}_infercna_with_preclassified_cells.tsv")
        targets.append(f"results/{mat_specific_dataset}_output/evaluation/bench_{mat_specific_dataset}_infercna_hg19_with_preclassified_cells.tsv")
        targets.append(f"results/{mat_specific_dataset}_output/evaluation/bench_{mat_specific_dataset}_infercnv_with_preclassified_cells.tsv")
        targets.append(f"results/{mat_specific_dataset}_output/evaluation/bench_{mat_specific_dataset}_infercnv_hg19_with_preclassified_cells.tsv")
        targets.append(f"results/{mat_specific_dataset}_output/evaluation/bench_{mat_specific_dataset}_copykat_with_preclassified_cells.tsv")
        targets.append(f"results/{mat_specific_dataset}_output/evaluation/bench_{mat_specific_dataset}_scevan_with_preclassified_cells.tsv")
        targets.append(f"results/{mat_specific_dataset}_output/evaluation/bench_{mat_specific_dataset}_CONICSmat_with_preclassified_cells.tsv")
        if MODE == "fastq" or MODE == "bam":
            targets.append(f"results/{mat_specific_dataset}_output/evaluation/bench_{mat_specific_dataset}_casper_with_preclassified_cells.tsv")
            targets.append(f"results/{mat_specific_dataset}_output/evaluation/bench_{mat_specific_dataset}_numbat_with_preclassified_cells.tsv")
    targets.append(f"results/{mat_specific_dataset}_output/evaluation/dataset_metrics.tsv")
    # per-dataset summary table (8 selected columns, built by plot_cnv_heatmaps.py)
    # targets.append(f"results/{mat_specific_dataset}_output/evaluation/dataset_summary.tsv")
    return targets

rule all:
    input:
        _default_targets()

# ==============================================================================
# FastQ ALIGNMENT RULES (BWA MEM for DNA, STAR SOLO for RNA)
# ==============================================================================

def None2StrNone(arg): return ('None' if arg == None else arg)

if MODE == "fastq":

    # ---- DNA-seq alignment using BWA MEM to hg19 ----
    rule align_dna_to_hg19:
        input:
            fqs = lambda wc: (
                [ALL_DNA_FQ1_OF[wc.cell]] +
                ([ALL_DNA_FQ2_OF.get(wc.cell)] 
                 if (ALL_DNA_FQ2_OF.get(wc.cell) and ALL_DNA_FQ2_OF.get(wc.cell) != "None") 
                 else [])
            )
        output:
            bam = f"results/{dataset}_bams/dna/{{cell}}_hg19.bam",
            bai = f"results/{dataset}_bams/dna/{{cell}}_hg19.bam.bai",
            stats = f"results/{dataset}_bams/dna/{{cell}}_hg19.bam.stats"
        log:
            f"logs/{DATASET}/{DATASET}_align_dna_to_hg19_{{cell}}.log"
        benchmark:
            f"benchmarks/{DATASET}/{DATASET}_align_dna_to_hg19_{{cell}}_benchmark.txt"
        params:
            ref = HG19_FASTA,
            bwa_mem_k = BWA_MEM_K,
            threads = BWA_THREADS,
            sort_threads = SORT_THREADS,
            sample_id = f"{dataset}_{{cell}}",
        shell:
            r"""
            set -euo pipefail
            mkdir -p $(dirname {output.bam})

            # Redirect all stdout/stderr from the entire pipeline to the log file
            exec > >(tee -a {log}) 2>&1

            bwa mem -R $'@RG\\tID:{params.sample_id}\\tSM:{params.sample_id}\\tLB:{params.sample_id}\\tPU:L001\\tPL:ILLUMINA' \
                -K {params.bwa_mem_k} -t {params.threads} "{params.ref}" {input.fqs} \
            | samtools fixmate -m - - \
            | samtools sort -@{params.sort_threads} -T /tmp/sort_{params.sample_id} -o - - \
            | samtools markdup - "{output.bam}"

            samtools stats "{output.bam}" > "{output.stats}"
            samtools index "{output.bam}"
            """

    # ---- Generate scWGS BAM paths from FastQ mode ----
    # These are derived from the DNA alignment outputs
    ALL_SCWGS_BAM_OF = {cid: f"results/{dataset}_bams/dna/{cid}_hg19.bam" for cid in ALL_CELL_IDS}
    REF_SCWGS_BAM_OF = {cid: f"results/{dataset}_bams/dna/{cid}_hg19.bam" for cid in REF_CELL_IDS}
    TUM_SCWGS_BAM_OF = {cid: f"results/{dataset}_bams/dna/{cid}_hg19.bam" for cid in TUM_CELL_IDS}

    # --------------------------------------------------------------------------
    # RNA: STAR SOLO with readFilesManifest (single pass for all cells)
    # --------------------------------------------------------------------------
    rule generate_star_manifest:
        output:
            manifest = f"results/{dataset}_bams/rna/all_cells.manifest.tsv"
        run:
            with open(output.manifest, "w") as m:
                for cell in ALL_CELL_IDS:
                    fq1 = ALL_RNA_FQ1_OF[cell]
                    fq2 = ALL_RNA_FQ2_OF.get(cell, "-")
                    if fq2 in ['None', 'none', 'Null', 'null', None]: fq2 = '-'
                    # STAR manifest: read1 [read2] sample_name
                    # For paired‑end, give both; for single‑end, second column empty
                    m.write(f"{fq1}\t{fq2}\t{cell}\n")

    # CAVEAT: please use "--soloUMIdedup Exact" if raw 10x (or 10x-like) data are inputted
    rule align_all_rna_to_grch38:
        input:
            manifest = rules.generate_star_manifest.output.manifest
        output:
            # Single BAM with RG tags (cell ID stored in CB tag by STAR solo)
            bam = f"results/{dataset}_bams/rna/all_cells_grch38.bam",
            bai = f"results/{dataset}_bams/rna/all_cells_grch38.bam.bai",
            # Solo output files (matrix + barcodes = cell IDs)
            matrix = f"results/{dataset}_bams/rna/all_cells_grch38_Solo.out/Gene/raw/matrix.mtx",
            barcodes = f"results/{dataset}_bams/rna/all_cells_grch38_Solo.out/Gene/raw/barcodes.tsv",
            features = f"results/{dataset}_bams/rna/all_cells_grch38_Solo.out/Gene/raw/features.tsv",
            matrix_genefull = f"results/{dataset}_bams/rna/all_cells_grch38_Solo.out/GeneFull/raw/matrix.mtx",
            barcodes_genefull = f"results/{dataset}_bams/rna/all_cells_grch38_Solo.out/GeneFull/raw/barcodes.tsv",
            features_genefull = f"results/{dataset}_bams/rna/all_cells_grch38_Solo.out/GeneFull/raw/features.tsv",
        log:
            f"logs/{DATASET}/{DATASET}_align_all_rna_to_grch38.log"
        benchmark:
            f"benchmarks/{DATASET}/{DATASET}_align_all_rna_to_grch38_benchmark.txt"
        threads: STAR_THREADS
        resources:
            mem_mb = 64000
        params:
            star_dir = STAR_GRCH38_DIR,
            star_prefix = f"results/{dataset}_bams/rna/all_cells_grch38_",
            star_tmp = f"/tmp/STAR-grch38-{dataset}",
            limit_bam_sort_ram = STAR_LIMIT_BAM_SORT_RAM,
            sjdb_overhang = SJDB_OVERHANG
        shell:
            r"""
            set -euo pipefail
            mkdir -p $(dirname {output.bam})
            rm -rf {params.star_tmp} || true

            STAR --readFilesManifest {input.manifest} \
                 --readFilesCommand zcat \
                 --outTmpDir {params.star_tmp} \
                 --genomeDir "{params.star_dir}" \
                 --outFileNamePrefix "{params.star_prefix}" \
                 --outSAMtype BAM SortedByCoordinate \
                 --quantMode GeneCounts \
                 --runThreadN {threads} \
                 {STAR_DETERMINISTIC_ARGS} \
                 --soloType SmartSeq \
                 --soloUMIdedup NoDedup \
                 --soloStrand Unstranded \
                 --soloFeatures Gene GeneFull \
                 --outSAMattributes RG NH HI AS nM \
                 2>{log}
            rm -r {params.star_tmp} || true
            # Move final BAM to expected location
            mv "{params.star_prefix}Aligned.sortedByCoord.out.bam" "{output.bam}"
            samtools index "{output.bam}"
            samtools stats "{output.bam}" > "{output.bam}.stats"
            """

    rule convert_star_solo_to_matrices:
        input:
            # Gene
            mtx_gene = rules.align_all_rna_to_grch38.output.matrix,
            barcodes_gene = rules.align_all_rna_to_grch38.output.barcodes,
            features_gene = rules.align_all_rna_to_grch38.output.features,
            # GeneFull
            mtx_genefull = rules.align_all_rna_to_grch38.output.matrix_genefull,
            barcodes_genefull = rules.align_all_rna_to_grch38.output.barcodes_genefull,
            features_genefull = rules.align_all_rna_to_grch38.output.features_genefull,
        output:
            # CSV: rows = cells, columns = genes, values = counts
            gene_tsv = f"results/{dataset}_bams/rna/cell_by_gene_Gene.tsv",
            genefull_tsv = f"results/{dataset}_bams/rna/cell_by_gene_GeneFull.tsv",
        log:
            f"logs/{mat_specific_dataset}/{mat_specific_dataset}_convert_star_solo.log"
        script:
            f"scripts/convert_star_solo.R"

    # ---- If downstream rules absolutely require per‑cell RNA BAMs ----
    # We can split the merged BAM by the CB tag (cell ID) that STAR added.
    # This step can be omitted if downstream tools are adapted to use the
    # merged BAM plus the cell barcodes from Solo.out.
    rule split_rna_bam_by_cell:
        input:
            bam = f"results/{dataset}_bams/rna/all_cells_grch38.bam"
        output:
            # This expands to a list of per‑cell BAM files
            per_cell_bams = expand(f"results/{dataset}_bams/rna/all_cells_grch38_{{cell}}.bam", cell=ALL_CELL_IDS),
            per_cell_bam_bais = expand(f"results/{dataset}_bams/rna/all_cells_grch38_{{cell}}.bam.bai", cell=ALL_CELL_IDS),
            per_cell_bam_stats = expand(f"results/{dataset}_bams/rna/all_cells_grch38_{{cell}}.bam.stats", cell=ALL_CELL_IDS),
        log:
            f"logs/{mat_specific_dataset}/{mat_specific_dataset}_split_rna_bam_by_cell.log"
        run:
            import subprocess as sp
            sp.run(f"OLD_DIR=\"$PWD\" && cd results/{dataset}_bams/rna/ && samtools split -@ 4 -f '%*_%!.%.' all_cells_grch38.bam && cd \"$OLD_DIR\"", shell=True, check=True)
            # Get the list of cell IDs from the manifest (or from ALL_CELL_IDS)
            # cells = {wildcards.cell for wildcards in output.per_cell_bams}
            for cell in ALL_CELL_IDS:
                out_bam = f"results/{dataset}_bams/rna/all_cells_grch38_{cell}.bam"
                # Use samtools view with filtering on CB tag
                # sp.run(f"samtools view -b -@ 2 -o {out_bam} {input.bam} 'CB:{cell}'", 
                #       shell=True, check=True)
                sp.run(f"samtools index {out_bam}", shell=True, check=True)
                sp.run(f"samtools stats {out_bam} > {out_bam}.stats", shell=True, check=True)

    # Define per‑cell RNA BAMs for compatibility with downstream rules
    ALL_SCRNA_BAM_OF = {cid: f"results/{dataset}_bams/rna/all_cells_grch38_{cid}.bam" for cid in ALL_CELL_IDS}
    REF_SCRNA_BAM_OF = {cid: f"results/{dataset}_bams/rna/all_cells_grch38_{cid}.bam" for cid in REF_CELL_IDS}
    TUM_SCRNA_BAM_OF = {cid: f"results/{dataset}_bams/rna/all_cells_grch38_{cid}.bam" for cid in TUM_CELL_IDS}

# <BAM_PREPROCESSING privateURL=https://www.doubao.com/chat/38422834392700674 publicURL=https://www.doubao.com/thread/wff4f40492a3fe6b4>

# Helper function to extract total reads from samtools stats file
def get_total_reads(stats_file):
    return 2**30 # keep everything
    """Parse samtools stats output to get 'raw total sequences' count."""
    with open(stats_file, 'r') as f:
        for line in f:
            # Look for the summary line with raw total sequences
            if line.startswith('SN\traw total sequences:'):
                # Split by tabs and take the 3rd field (value)
                return int(line.strip().split('\t')[2])
    return 0  # Fallback if line not found

KEPT_CELL_IDS = []
for cell_ID in ALL_CELL_IDS:
    dna_stats = ALL_SCWGS_BAM_OF[cell_ID] + '.stats'
    rna_stats = ALL_SCRNA_BAM_OF[cell_ID] + '.stats'
    
    # Get read counts from both stats files
    dna_reads = get_total_reads(dna_stats)
    rna_reads = get_total_reads(rna_stats)
    
    # Apply filtering thresholds
    if dna_reads >= 10000 and rna_reads >= 500:
        KEPT_CELL_IDS.append(cell_ID)

OLD_ALL_CELL_IDS = ALL_CELL_IDS
OLD_ALL_SCWGS_BAM_OF = ALL_SCWGS_BAM_OF
OLD_ALL_SCRNA_BAM_OF = ALL_SCRNA_BAM_OF

DISCARDED_CELL_IDS = list(set(ALL_CELL_IDS) - set(KEPT_CELL_IDS))
print(f"Kept the cells: {KEPT_CELL_IDS}")
print(f"Discarded the cells: {DISCARDED_CELL_IDS}")

ALL_CELL_IDS = KEPT_CELL_IDS
ALL_SCWGS_BAM_OF = {cid : OLD_ALL_SCWGS_BAM_OF[cid] for cid in ALL_CELL_IDS}
ALL_SCRNA_BAM_OF = {cid : OLD_ALL_SCRNA_BAM_OF[cid] for cid in ALL_CELL_IDS}

# <BAM_PREPROCESSING>

# ==============================================================================
# STEP 1: Generate ground truth from scWGS via Ginkgo, then liftover to GRCh38
# ==============================================================================

rule scwgs_bam_to_bed:
    input:
        bam = lambda wc: ALL_SCWGS_BAM_OF[wc.cell]
    output:
        bed = f"results/{dataset}_ginkgo/truth_calls/{{cell}}.bed"
        # the keyword "bed" should only appear at the end of the bed file because this keyword is used as the separator token in awk
        # https://github.com/robertaboukhalil/ginkgo/blob/d7c779027f64fd22efe733d29be8b551c3e94f72/cli/ginkgo.sh#L137
    log:
        f"logs/{DATASET}/{DATASET}_scwgs_bam_to_bed_{{cell}}.log"
    benchmark:
        f"benchmarks/{DATASET}/{DATASET}_scwgs_bam_to_bed_{{cell}}_benchmark.txt"
    threads: 1
    resources:
        mem_mb = 4000
    shell:
        r"""
        set -euo pipefail
        mkdir -p $(dirname {output.bed})
        bedtools bamtobed -i {input.bam} > {output.bed} 2>{log}
        """

rule run_ginkgo:
    input:
        truth_calls = expand(f"results/{dataset}_ginkgo/truth_calls/{{cell}}.bed", cell=ALL_CELL_IDS)
    output:
        segcopy = f"results/{dataset}_ginkgo/output/SegCopy"
    log:
        f"logs/{DATASET}/{DATASET}_run_ginkgo.log"
    benchmark:
        f"benchmarks/{DATASET}/{DATASET}_run_ginkgo_benchmark.txt"
    threads: 1
    resources:
        mem_mb = 16000
    params:
        ginkgo_env = GINKGO_ENV,
        ginkgo_sh = GINKGO_SH,
        bed_dir = f"results/{dataset}_ginkgo/truth_calls",
        genome = GINKGO_GENOME,
        binning = GINKGO_BINNING
    shell:
        r"""
        set -euo pipefail
        mkdir -p $(dirname {output.segcopy})
        conda run -n {params.ginkgo_env} bash {params.ginkgo_sh} \
            --input $(realpath {params.bed_dir})/ \
            --genome {params.genome} \
            --binning {params.binning} \
            2>&1 | tee {log}
        cp {params.bed_dir}/SegCopy {output.segcopy}
        test -f {output.segcopy} || {{ echo "ERROR: Ginkgo did not produce SegCopy" >&2; exit 1; }}
        """

rule liftover_ginkgo_results:
    input:
        segcopy = f"results/{dataset}_ginkgo/output/SegCopy"
    output:
        segcopy_grch38 = f"results/{dataset}_ginkgo/output/SegCopy_grch38.tsv",
        unmapped = f"results/{dataset}_ginkgo/output/SegCopy_unmapped.bed"
    log:
        f"logs/{DATASET}/{DATASET}_liftover_ginkgo.log"
    benchmark:
        f"benchmarks/{DATASET}/{DATASET}_liftover_ginkgo_benchmark.txt"
    threads: 1
    resources:
        mem_mb = 4000
    params:
        chain = LIFTOVER_CHAIN,
        liftover_bin = LIFTOVER_BIN
    shell:
        r"""
        set -euo pipefail
        exec 2>{log}

        TMPDIR=$(mktemp -d)
        trap 'rm -rf "$TMPDIR"' EXIT

        head -n1 {input.segcopy} > "$TMPDIR/header.txt"

        tail -n+2 {input.segcopy} | awk -F'\t' 'BEGIN{{OFS="\t"}} {{
            chr = $1;
            if (chr !~ /^chr/) chr = "chr" chr;
            print chr, $2, $3, NR;
        }}' > "$TMPDIR/input.bed"

        tail -n+2 {input.segcopy} | cut -f4- > "$TMPDIR/data_cols.tsv"

        {params.liftover_bin} \
            "$TMPDIR/input.bed" \
            {params.chain} \
            "$TMPDIR/lifted.bed" \
            {output.unmapped}

        python3 -c "
import sys

data = {{}}
with open('$TMPDIR/data_cols.tsv') as f:
    for i, line in enumerate(f, 1):
        data[i] = line.rstrip('\n')

with open('$TMPDIR/lifted.bed') as fin, open('$TMPDIR/body.tsv', 'w') as fout:
    for line in fin:
        parts = line.rstrip('\n').split('\t')
        chrom, start, end, orig_nr = parts[0], parts[1], parts[2], int(parts[3])
        if orig_nr in data:
            fout.write(f'{{chrom}}\t{{start}}\t{{end}}\t{{data[orig_nr]}}\n')
"

        head -n1 {input.segcopy} > {output.segcopy_grch38}
        sort -k1,1V -k2,2n "$TMPDIR/body.tsv" >> {output.segcopy_grch38}
        """

DNA_CELL_ANNOTATION = f"data/{dataset}_ginkgo_groundtruth/dna_cell_annotation.txt"

rule format_ginkgo_ground_truth:
    input:
        segcopy_hg19 = f"results/{dataset}_ginkgo/output/SegCopy",
        segcopy_grch38 = f"results/{dataset}_ginkgo/output/SegCopy_grch38.tsv",
    output:
        ground_truth_hg19 = f"data/{dataset}_ginkgo_groundtruth/wgs_results_formated_hg19.csv",
        ground_truth = f"data/{dataset}_ginkgo_groundtruth/wgs_results_formated.csv",
        ground_truth_tn_classification = DNA_CELL_ANNOTATION,
    log:
        f"logs/{dataset}/{dataset}_format_ginkgo_ground_truth.log"
    benchmark:
        f"benchmarks/{dataset}/{dataset}_format_ginkgo_ground_truth_{dataset}_benchmark.txt"
    threads: 1
    resources:
        mem_mb = 4000
    run:
        shell(f'cp {input.segcopy_hg19} {output.ground_truth_hg19}')
        shell(f'cp {input.segcopy_grch38} {output.ground_truth}')
        #        for gdir in /nfs/wxz/zxf/cnv/copy-num-bench-scwgs-to-scrna/results/*_ginkgo/truth_calls/ ; do echo python3 /nfs/wxz/zxf/cnv/copy-num-bench-scwgs-to-scrna/snakemake_pipeline/scripts/separate_tumor_normal_from_ginkgo_segcopy.py $gdir/SegCopy $gdir/dna_cell_annotation.txt threshold_diploid_percent 85 ; done | parallel -j 32
        shell(f'python {workflow.basedir}/scripts/separate_tumor_normal_from_ginkgo_segcopy.py {input.segcopy_hg19} {output.ground_truth_tn_classification} threshold_diploid_percent 85')

rule format_ginkgo_ground_truth_percell:
    input:
        segcopy_grch38 = f"results/{dataset}_ginkgo/output/SegCopy_grch38.tsv"
    output:
        percell_gt = f"data/{dataset}_ginkgo_groundtruth/cnvs_per_cell_filtered.tsv"
    log:
        f"logs/{dataset}/{dataset}_format_ginkgo_percell_gt.log"
    threads: 1
    resources:
        mem_mb = 4000
    run:
        import csv, os
        os.makedirs(os.path.dirname(output.percell_gt), exist_ok=True)
        with open(input.segcopy_grch38) as fin, \
             open(output.percell_gt, "w", newline="") as fout:
            reader = csv.reader(fin, delimiter="\t")
            header = next(reader)
            cell_names = header[3:]
            writer = csv.writer(fout, delimiter="\t")
            writer.writerow(["chr", "start", "end", "cell", "copy_number"])
            for row in reader:
                if len(row) < 4:
                    continue
                chrom, start, end = row[0], row[1], row[2]
                for i, cn in enumerate(row[3:]):
                    if i < len(cell_names):
                        try:
                            cn_val = float(cn)
                            writer.writerow([chrom, start, end, cell_names[i], f"{cn_val:.2f}"])
                        except ValueError:
                            pass


# ==============================================================================
# STEP 2: Prepare inputs for CNV callers
# ==============================================================================

if MODE == "fastq" or MODE == "bam":

    rule index_scrna_bam:
        input:
            bam = lambda wc: ALL_SCRNA_BAM_OF[wc.cell]
        output:
            bai = f"results/output_{dataset}/bam_indices/{{cell}}.bam.bai"
        log:
            f"logs/{dataset}/{dataset}_index_scrna_bam_{{cell}}.log"
        threads: 1
        resources:
            mem_mb = 4000
        shell:
            r"""
            set -euo pipefail
            BAM_PATH=$(readlink -f {input.bam})
            samtools index "$BAM_PATH" {output.bai} 2>{log}
            """

    rule generate_count_matrix:
        input:
            bams = [ALL_SCRNA_BAM_OF[c] for c in ALL_CELL_IDS],
            gtf = GTF_GRCH38
        output:
            count_matrix = f"data/{DATASET}_input/featurecounts_matrix.txt", # with the original header defined by https://github.com/colomemaria/benchmark_scrnaseq_cnv_callers
            count_matrix_with_hdr = f"data/{DATASET}_input/featurecounts_matrix.with_fixed_header.txt", # with header revised for human readability
            summary = f"data/{DATASET}_input/featurecounts_summary.txt"
        log:
            f"logs/{DATASET}/{DATASET}_generate_count_matrix.log"
        benchmark:
            f"benchmarks/{DATASET}/{DATASET}_generate_count_matrix_benchmark.txt"
        threads: 4
        resources:
            mem_mb = 16000
        run:
            import subprocess, sys, os
            os.makedirs(os.path.dirname(output.count_matrix), exist_ok=True)

            bam_list = input.bams
            tmpout = output.count_matrix + ".fc_raw"

            assert len(bam_list) >= 1, f'No input bam files detected!'

            cmd = [
                "featureCounts",
                "-a", input.gtf,
                "-o", tmpout,
                "-T", str(threads),
                "-t", "gene",
                "-g", "gene_name",
                "--primary",
                "--ignoreDup",
            ]
 
            subcmd = ["samtools", "flagstat", bam_list[0]]
            subresult = subprocess.run(subcmd, capture_output=True, text=True)
            if not '0 + 0 paired in sequencing' in subresult.stdout:
                cmd.append("-p")
            cmd.extend(list(bam_list))

            result = subprocess.run(cmd, capture_output=True, text=True)
            if result.returncode != 0:
                print(result.stderr, file=sys.stderr)
                sys.exit(result.returncode)

            cell_ids = list(ALL_CELL_IDS)
            with open(tmpout) as fin, open(output.count_matrix, "w") as fout, open(output.count_matrix_with_hdr, "w") as fout_header:
                for line in fin:
                    if line.startswith("#"):
                        continue
                    parts = line.rstrip("\n").split("\t")
                    if parts[0] == "Geneid":
                        fout_header.write("gene\t" + "\t".join(cell_ids) + "\n")
                        fout.write("V1\t" + "\t".join(cell_ids) + "\n") # The V1 denotes GeneID
                    else:
                        gene = parts[0]
                        counts = parts[6:]
                        record = gene + "\t" + "\t".join(counts) + "\n"
                        fout_header.write(record)
                        fout.write(record)

            with open(output.summary, "w") as f:
                f.write(f"Cells: {len(cell_ids)}\n")
                f.write(f"BAMs: {len(bam_list)}\n")

            os.remove(tmpout)
            if os.path.exists(tmpout + ".summary"):
                os.rename(tmpout + ".summary", output.summary)

else:

    rule prepare_count_matrix_from_file:
        input:
            raw_matrix = INPUT_MATRIX_FILE
        output:
            count_matrix = f"data/{DATASET}_input/count_matrix.txt",
            summary = f"data/{DATASET}_input/matrix_import_summary.txt"
        log:
            f"logs/{DATASET}/{DATASET}_prepare_count_matrix_from_file.log"
        benchmark:
            f"benchmarks/{DATASET}/{DATASET}_prepare_count_matrix_from_file_benchmark.txt"
        threads: 1
        resources:
            mem_mb = 8000
        params:
            required_cell_ids = ";".join(ALL_CELL_IDS)
        run:
            import os, sys, csv

            os.makedirs(os.path.dirname(output.count_matrix), exist_ok=True)

            required = set(params.required_cell_ids.split(";")) if params.required_cell_ids else set()

            with open(log[0], "w") as logf:
                logf.write(f"Input matrix: {input.raw_matrix}\n")
                logf.write(f"Required cell IDs ({len(required)}): {sorted(required)}\n")

                with open(input.raw_matrix) as fin:
                    header_line = fin.readline().rstrip("\n")

                if "\t" in header_line:
                    delim = "\t"
                else:
                    delim = None

                header_fields = header_line.split(delim)
                gene_col_name = header_fields[0]
                matrix_cell_ids = header_fields[1:]

                logf.write(f"Matrix columns ({len(matrix_cell_ids)}): {matrix_cell_ids[:20]}...\n")

                matrix_cell_set = set(matrix_cell_ids)
                missing = required - matrix_cell_set
                if missing:
                    msg = (
                        f"ERROR: The following cell IDs from scWGS_matrix_pairs "
                        f"are not found as columns in the matrix file: {sorted(missing)}"
                    )
                    logf.write(msg + "\n")
                    print(msg, file=sys.stderr)
                    sys.exit(1)

                if required:
                    keep_indices = [0]
                    for i, cid in enumerate(matrix_cell_ids):
                        if cid in required:
                            keep_indices.append(i + 1)
                    kept_cell_ids = [matrix_cell_ids[i - 1] for i in keep_indices[1:]]
                else:
                    keep_indices = list(range(len(header_fields)))
                    kept_cell_ids = matrix_cell_ids

                logf.write(f"Keeping {len(kept_cell_ids)} cell columns\n")

                n_genes = 0
                with open(input.raw_matrix) as fin, \
                     open(output.count_matrix, "w") as fout:
                    for line_no, line in enumerate(fin):
                        fields = line.rstrip("\n").split(delim)
                        selected = [fields[i] for i in keep_indices if i < len(fields)]
                        fout.write("\t".join(selected) + "\n")
                        if line_no > 0:
                            n_genes += 1

                logf.write(f"Wrote {n_genes} genes x {len(kept_cell_ids)} cells\n")

            with open(output.summary, "w") as f:
                f.write(f"Mode: matrix_import\n")
                f.write(f"Source: {input.raw_matrix}\n")
                f.write(f"Cells kept: {len(kept_cell_ids)}\n")
                f.write(f"Genes: {n_genes}\n")
                f.write(f"Tumor cells: {len(TUM_CELL_IDS)}\n")
                f.write(f"Reference cells: {len(REF_CELL_IDS)}\n")

ORI_CELL_ANNOTATION = f"data/{DATASET}_input/sample_annotation_1.txt"

rule create_sample_annotation_1:
    output:
        annot = ORI_CELL_ANNOTATION,
    log:
        f"logs/{DATASET}/{DATASET}_create_sample_annotation_1.log"
    threads: 1
    run:
        import os
        os.makedirs(os.path.dirname(output.annot), exist_ok=True)
        with open(output.annot, "w") as f:
            for cid in ALL_CELL_IDS:
                # When the config declined to label cells (all "Unknown"), the
                # tumor/normal origin is NOT author-provided. Write 'unknown' so
                # downstream scripts (evaluate_caller_vs_ginkgo.py,
                # compute_dataset_metrics.py) detect the placeholder and fall back
                # to the DNA (Ginkgo) labeling rather than trusting these labels.
                if ALL_CONFIG_UNKNOWN:
                    cell_type = 'unknown'
                else:
                    cell_type = ('tumor' if (cid in TUM_CELL_IDS) else 'reference')
                f.write(f"{cid}\t{cell_type}\n")

RNA_CELL_ANNOTATION = SELECTED_COUNT_MATRIX + '.annotation.txt'
RNA_BEST_ANNOTATION = f"data/{DATASET}_input/sample_annotation_2.txt"
DNA_BEST_ANNOTATION = f"data/{DATASET}_input/dna_best_annotation.txt"

rule create_DNA_best_annotation:
    input:
        annot1 = ORI_CELL_ANNOTATION,
        annot2 = DNA_CELL_ANNOTATION, # e.g., cell_by_gene_GeneFull.tsv
    output:
        annot = DNA_BEST_ANNOTATION,
    log:
        f"logs/{DATASET}/{DATASET}_create_DNA_best_annotation.log"
    threads: 1
    run:
        import shutil
        if HAS_REF_CELLS:
            shutil.copy(input.annot1, output.annot)
        else:
            shutil.copy(input.annot2, output.annot)

rule create_sample_annotation_2:
    input:
        #annot1 = ORI_CELL_ANNOTATION,
        in_mat = SELECTED_COUNT_MATRIX, # e.g., cell_by_gene_GeneFull.tsv
