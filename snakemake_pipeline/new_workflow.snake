            results = f"results/{mat_specific_dataset}_output/evaluation/bench_{mat_specific_dataset}_copykat_without_preclassified_cells.tsv"
        log:
            f"logs/{mat_specific_dataset}/{mat_specific_dataset}_evaluate_copykat_without_preclassified_cells.log"
        benchmark:
            f"benchmarks/{mat_specific_dataset}/{mat_specific_dataset}_evaluate_copykat_without_preclassified_cells_benchmark.txt"
        threads: 1
        resources:
            mem_mb = 16000
        run:
            import subprocess, sys, os
            os.makedirs(os.path.dirname(output.results), exist_ok=True)
            shell(
                r"""
                set -euo pipefail
                python3 {workflow.basedir}/scripts/evaluate_caller_vs_ginkgo.py \
                    --ground-truth {input.ground_truth} \
                    --caller-result {input.copykat} \
                    --caller-name copykat_predict \
                    --gene-pos {input.gene_pos} \
                    --sample-annotation {input.samp_annot} --dna-annotation {input.dna_annot} --rna-annotation {input.rna_annot} \
                    --output {output.results} \
                    2>{log}
                """
            )

if always_has_ref_cells:

