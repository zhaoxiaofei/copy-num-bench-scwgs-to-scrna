    log:
        f"logs/{DATASET}/{DATASET}_create_sample_annotation_2.log"
    threads: 1
    run:
        import shutil
        shell(r'''Rscript {workflow.basedir}/scripts/identify_normal_cell_subset.R {input.in_mat}''')

