# ==============================================================================
# STEP 3: Evaluate CNV calling results against Ginkgo ground truth
# ==============================================================================

# Evaluate InferCNV (requiring ref cells IDs)

if HAS_REF_CELLS:

    rule evaluate_infercnv_with_given_refs:
        input:
            ground_truth = f"data/{DATASET}_ginkgo_groundtruth/wgs_results_formated.csv",
            infercnv_cnv = f"results/output_{DATASET}/infercnv_known_ref/infercnv.20_HMM_predHMMi6.leiden.hmm_mode-subclusters.Pnorm_0.5.repr_intensities.observations.txt",
            infercnv_expr = f"results/output_{DATASET}/infercnv_known_ref/infercnv.observations.txt",
            gene_pos = GENE_POS_FILE,
            samp_annot = f"data/input_{DATASET}/sample_annotation.txt",
        output:
            results = f"results/output_{DATASET}/evaluation/evaluation_infercnv_with_preclassified_cells.tsv"
        log:
            f"logs/evaluate_infercnv_with_preclassified_cells_{DATASET}.log"
        benchmark:
            f"benchmarks/evaluate_infercnv_with_preclassified_cells_{DATASET}.txt"
        threads: 1
        resources:
            mem_mb = 16000
        shell:
            r"""
            set -euo pipefail
            python3 {workflow.basedir}/scripts/evaluate_caller_vs_ginkgo.py \
                --ground-truth {input.ground_truth} \
                --caller-result {input.infercnv_cnv} \
                --caller-name infercnv \
                --sample-annotation {input.samp_annot} \
                --gene-pos {input.gene_pos} \
                --output {output.results} \
                2>{log}
            """

    rule evaluate_infercnv_with_ref_using_hg19:
        input:
            ground_truth = f"data/{DATASET}_ginkgo_groundtruth/wgs_results_formated_hg19.csv",
            infercnv_cnv = f"results/output_{DATASET}/infercnv_known_ref_hg19/infercnv.20_HMM_predHMMi6.leiden.hmm_mode-subclusters.Pnorm_0.5.repr_intensities.observations.txt",
            infercnv_expr = f"results/output_{DATASET}/infercnv_known_ref_hg19/infercnv.observations.txt",
            gene_pos = GENE_POS_FILE_HG19,
            samp_annot = f"data/input_{DATASET}/sample_annotation.txt",
        output:
            results = f"results/output_{DATASET}/evaluation/evaluation_infercnv_hg19.tsv"
        log:
            f"logs/evaluate_infercnv_with_preclassified_cells_{DATASET}_hg19.log"
        benchmark:
            f"benchmarks/evaluate_infercnv_with_preclassified_cells_{DATASET}_hg19.txt"
        threads: 1
        resources:
            mem_mb = 16000
        shell:
            r"""
            set -euo pipefail
            python3 {workflow.basedir}/scripts/evaluate_caller_vs_ginkgo.py \
                --ground-truth {input.ground_truth} \
