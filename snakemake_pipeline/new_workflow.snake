            f"logs/{mat_specific_dataset}/{mat_specific_dataset}_infercnv_hg19.log"
        benchmark:
            f"benchmarks/{mat_specific_dataset}/{mat_specific_dataset}_infercnv_hg19_benchmark.txt"
